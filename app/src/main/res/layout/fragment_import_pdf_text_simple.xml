<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.ImportPdfTextFragmentSimple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Estado actual -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona un PDF para extraer texto"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <!-- Progress indicator -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <!-- Botón para seleccionar PDF -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectPdf"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            android:text="Seleccionar PDF"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp" />

        <!-- Botón grande verde cuando PDF está listo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPdfReady"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:text="PDF LISTO"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="@android:color/holo_green_dark"
            app:cornerRadius="16dp" />

        <!-- Botón para guardar texto -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Texto Extraído"
            android:textColor="@android:color/black"
            android:paddingVertical="14dp"
            android:visibility="gone"
            app:backgroundTint="@color/gold"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp" />

        <!-- Texto extraído -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/extractedTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="16dp"
            android:background="@color/white"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:visibility="gone"
            android:scrollbars="vertical"
            android:maxHeight="300dp"
            tools:text="Aquí aparecerá el texto extraído del PDF..." />

    </LinearLayout>

</ScrollView>