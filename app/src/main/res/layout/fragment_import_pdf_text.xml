<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.viewmodel.ui.ImportPdfTextFragment">

    <LinearLayout
        android:id="@+id/selectLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectPdf"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Seleccionar PDF"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:paddingVertical="14dp"
            app:backgroundTint="@color/white"
            app:icon="@drawable/file_open_pdf"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@android:color/black"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Procesando PDF..."
            android:textSize="16sp"
            android:textColor="@android:color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/readyLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="64sp"
            android:textColor="@android:color/holo_green_dark"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Texto listo para guardar"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Guardar"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:paddingVertical="14dp"
            app:backgroundTint="@color/gold"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

</FrameLayout>
