<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.ImportPdfTextFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Botón para seleccionar PDF -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectPdf"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            android:text="Seleccionar PDF"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp" />

        <!-- Estado de carga -->
        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Procesando PDF..."
                android:textSize="16sp"
                android:textColor="@android:color/black" />

        </LinearLayout>

        <!-- Botón grande cuando PDF está listo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPdfListo"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp"
            android:text="PDF LISTO"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="@android:color/holo_green_dark"
            app:cornerRadius="16dp" />

        <!-- Botón para guardar texto -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/SaveTextButtonTextPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Texto Extraído"
            android:textColor="@android:color/black"
            android:paddingVertical="14dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@color/gold"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp" />

        <!-- Texto extraído -->
        <TextView
            android:id="@+id/textPdfExtracted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@color/white"
            android:text="Aquí irá el texto extraído..."
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:visibility="gone"
            android:scrollbars="vertical"
            android:maxHeight="300dp" />

    </LinearLayout>

</ScrollView>