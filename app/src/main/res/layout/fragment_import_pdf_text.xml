<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".ui.ImportPdfTextFragment">

    <LinearLayout
        android:id="@+id/selectLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Importar PDF"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Selecciona un PDF con texto legible para extraer su contenido."
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:alpha="0.75" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectPdf"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:paddingVertical="14dp"
            android:text="Seleccionar PDF"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:backgroundTint="@color/gold"
            app:cornerRadius="10dp"
            app:icon="@drawable/file_open_pdf"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@android:color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Procesando PDF..."
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/readyLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Listo"
            android:textColor="@android:color/holo_green_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Texto listo para guardar"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:paddingVertical="14dp"
            android:text="Guardar"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:backgroundTint="@color/gold"
            app:cornerRadius="10dp" />

    </LinearLayout>

</FrameLayout>
